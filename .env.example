# Copy this file to .env and fill in your values.

SECRET_KEY=change-me
DATABASE_URL=sqlite:///museum.db

# Google SMTP email alerts (used when motion or smoke is detected)
ENABLE_EMAIL_ALERTS=false
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=youraddress@gmail.com
MAIL_PASSWORD=your-16-char-app-password
MAIL_SENDER=youraddress@gmail.com
ALERT_RECIPIENTS=staff1@example.com,staff2@example.com

# Alert thresholds
TEMP_MAX=45
HUMIDITY_MAX=80
